{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ECharts Studio",
  "version": "0.0.2",
  "identifier": "com.echarts-studio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ECharts Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwNDhEOEMxMEE4RERDOQpSV1RKM2FnUWpJMEVCZnNGbUZiWWR3TnVhN1lZbXR2TXR2Y1drby80WVBDM0tQbEN4WlBQUzIxRgo=",
      "endpoints": [
        "https://github.com/Michediana/Echarts-Studio/releases/latest/download/latest.json"
      ]
    }
  }
}
